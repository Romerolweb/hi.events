# Hi.Events All-in-One — Local Environment
# Copy this file to .env.aio-local and fill in the values below.
#
# Generate secrets:
#   APP_KEY:    echo "base64:$(openssl rand -base64 32)"
#   JWT_SECRET: openssl rand -base64 32
#
# Then run:
#   docker compose -f docker-compose.aio-local.yml --env-file .env.aio-local up --build

# ── Required secrets (no defaults — compose will error if missing) ──────────
APP_KEY=
JWT_SECRET=

# ── Postgres password (defaults to "secret" if left empty) ──────────────────
POSTGRES_PASSWORD=secret

# ── Stripe (leave empty to disable payments) ────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
